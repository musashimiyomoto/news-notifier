# --- Database ---
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/murderer

# --- Queue ---
REDIS_URL=redis://localhost:6379/0

# --- Ollama (via `docker compose up ollama` + `docker compose run --rm ollama-pull`,
#     or a native `ollama pull qwen3:4b qwen3:8b nomic-embed-text` + `ollama serve`) ---
OLLAMA_HOST=http://localhost:11434
LLM_QUERY_GEN_MODEL=qwen3:4b
LLM_EXTRACTION_MODEL=qwen3:8b
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_DIM=768

# --- Security ---
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SECRET_ENCRYPTION_KEY=change-me-generate-a-fernet-key

# --- Scheduling / scraping tuning ---
DEFAULT_POLL_INTERVAL_MINUTES=1440
VECTOR_DEDUP_THRESHOLD=0.90
SIMHASH_HAMMING_THRESHOLD=3
MAX_DELIVERY_ATTEMPTS=6
PLAYWRIGHT_TIMEOUT_MS=15000
SCRAPE_CONCURRENCY=5
SEARCH_RESULTS_PER_SOURCE=8
