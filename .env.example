# --- Database ---
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/news_notifier

# --- Queue ---
REDIS_URL=redis://localhost:6379/0

# --- LLM (query-gen + extraction/scoring) — local llama.cpp server by default,
# see the `llm` service in docker-compose.yml (no API key needed). Model names
# below are ignored by llama.cpp in single-model mode.
LLM_BASE_URL=http://localhost:8080/v1
LLM_API_KEY=
LLM_QUERY_GEN_MODEL=local
LLM_EXTRACTION_MODEL=local
# Local CPU inference is slow — a long-article extraction can take minutes. Keep
# this timeout generous; too tight and every call raises ReadTimeout and the
# candidate is silently dropped. Worker job_timeout tracks this automatically.
LLM_REQUEST_TIMEOUT_SECONDS=600
# Chars of article fed to the extraction prompt. Prompt-eval dominates CPU cost,
# so this directly bounds latency; the article lead holds most of the signal.
EXTRACTION_MAX_CHARS=4000
# The default local model (Qwen3-1.7B) is a reasoning model — suppress its
# <think> block (~2.5x tokens for no gain here). Set false for a non-thinking
# model (the Qwen3-4B-Instruct alternative in docker-compose) or a cloud API
# whose chat template doesn't accept the enable_thinking kwarg.
LLM_DISABLE_THINKING=true

# --- Want a cloud LLM instead? Comment out the 4 lines above and uncomment
# these (https://openrouter.ai/keys) — LLMClient (app/llm/client.py) just
# needs an OpenAI-compatible base_url, so no code changes required. ---
# LLM_BASE_URL=https://openrouter.ai/api/v1
# LLM_API_KEY=sk-or-v1-your-key-here
# LLM_QUERY_GEN_MODEL=openai/gpt-4o-mini
# LLM_EXTRACTION_MODEL=openai/gpt-4o-mini

# --- Embeddings — local FastEmbed model, no API key needed ---
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIM=384

# --- Security ---
# This is a valid Fernet key so things run out of the box, but it's public
# (checked into source) — generate your own before deploying anywhere real:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SECRET_ENCRYPTION_KEY=oMzYJ7UzyUqHOowktrH_dHkBBwMbW9QS_QGcoJMeHbU=

# Required on every /markets/* and /scrape-failures request as
# `Authorization: Bearer <API_KEY>` (see app/security.py:require_api_key).
# subscribe isn't a cheap read — it kicks off a recurring search+scrape+LLM
# pipeline per market — and PATCH can rewrite an existing market's callback_url,
# so leaving this open on anything reachable from outside your network is a
# resource-exhaustion / webhook-hijack risk. Unset (default) disables the check
# — fine for local dev and the /ui page, NOT fine for a public deployment.
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(32))"
API_KEY=

# --- Scheduling / scraping tuning ---
DEFAULT_POLL_INTERVAL_MINUTES=1440
# Randomizes each market's computed next_poll_at by +/- this fraction so markets
# sharing a cadence tier don't all wake up in the same worker tick. 0 disables.
POLL_JITTER_FRACTION=0.15
VECTOR_DEDUP_THRESHOLD=0.90
SIMHASH_HAMMING_THRESHOLD=3
MAX_DELIVERY_ATTEMPTS=6
PLAYWRIGHT_TIMEOUT_MS=15000
SCRAPE_CONCURRENCY=5
SEARCH_RESULTS_PER_SOURCE=8
# --- Candidate pre-filter (runs before the expensive scrape + LLM per URL) ---
# Keep only the top-K candidates most semantically similar (by title) to the
# market; drop those below the similarity floor. top_k=0 disables the filter.
CANDIDATE_PREFILTER_TOP_K=15
CANDIDATE_PREFILTER_MIN_SIMILARITY=0.30
# Drop candidates older than this many days (missing/unparseable dates are kept).
# 0 disables the recency filter.
CANDIDATE_MAX_AGE_DAYS=30
